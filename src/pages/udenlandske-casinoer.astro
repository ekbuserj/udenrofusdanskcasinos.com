---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/TrustBar.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import OfferWall from '../components/OfferWall.astro';
import OfferReprise from '../components/OfferReprise.astro';
import Faq from '../components/Faq.astro';
import AuthorBox from '../components/AuthorBox.astro';
import RelatedPages from '../components/RelatedPages.astro';
import CasinoMention from '../components/CasinoMention.astro';
import { CASINOS } from '../config/casinos';
import { CLUSTER_PAGES, FAQ_ITEMS } from '../config/site';
import {
  buildGraph, organizationSchema, websiteSchema, authorSchema,
  webPageSchema, articleSchema, breadcrumbSchema, faqSchema, casinoItemListSchema,
} from '../lib/schema';

const page = CLUSTER_PAGES[1];
const schema = buildGraph([
  organizationSchema(), websiteSchema(), authorSchema(),
  webPageSchema({ path: page.path, title: page.title, description: page.description }),
  articleSchema({ path: page.path, title: page.title, description: page.description, headline: page.h1 }),
  breadcrumbSchema([{ name: 'Forside', path: '/' }, { name: 'Udenlandske casinoer', path: page.path }]),
  casinoItemListSchema(CASINOS, page.path, 'Bedste udenlandske casino 2026'),
  faqSchema(FAQ_ITEMS.slice(0, 6)),
]);
---

<BaseLayout title={page.title} description={page.description} path={page.path} keywords={page.keywords} schema={schema}>
  <TrustBar />
  <div class="container page-layout">
    <Breadcrumbs crumbs={[{ name: 'Forside', path: '/' }, { name: 'Udenlandske casinoer', path: page.path }]} />
    <PageHero compact h1={page.h1} intro="Sammenlign de bedste udenlandske casinoer uden dansk licens — testet med rigtige indbetalinger og udbetalinger i 2026." />
    <OfferWall title="Top udenlandske casinoer" subtitle="International licens · Ingen ROFUS · Store bonusser" />

    <article class="prose content reveal">
      <section>
        <h2>Hvad er et udenlandsk casino?</h2>
        <p>
          Et <strong>udenlandsk casino</strong> (eller <strong>udenlandske casinoer</strong>) er en spilleside licenseret uden for Danmark — typisk under Malta, Curaçao eller Gibraltar. De opererer lovligt internationalt, men har ikke dansk Spillemyndigheds-licens og er derfor ikke koblet til ROFUS eller MitID.
        </p>
        <p>
          For danske spillere betyder det større bonusser, bredere spiludvalg og hurtigere registrering. Vores #1 anbefaling er <CasinoMention slug="godz" /> med score 10/10.
        </p>
      </section>

      <section>
        <h2>Bedste udenlandske casino: Sådan vælger du</h2>
        <p>Når du leder efter det <strong>bedste udenlandske casino</strong>, bør du vurdere:</p>
        <ul>
          <li><strong>Licens</strong> — Gyldig international licens og transparent ejerskab</li>
          <li><strong>Bonus</strong> — Matchprocent, free spins og omsætningskrav</li>
          <li><strong>Udbetaling</strong> — Behandlingstid og tilgængelige metoder</li>
          <li><strong>Spil</strong> — Antal slots, live casino og jackpot-udvalg</li>
          <li><strong>Support</strong> — Live chat, e-mail og svartid</li>
        </ul>
      </section>

      <section>
        <h2>Skatteforhold for danskere</h2>
        <p>
          Gevinster fra casinoer med EU-licens (fx Malta) er som udgangspunkt skattefrie. Gevinster fra Curaçao-licenserede sider kan være skattepligtige. Konsulter altid Skattestyrelsen ved tvivl.
        </p>
      </section>

      <section>
        <h2>Udenlandsk casino vs. dansk casino</h2>
        <p>
          Danske casinoer tilbyder ROFUS-beskyttelse og MitID-login, men begrænsede bonusser og indskudsgrænser. Udenlandske casinoer som <CasinoMention slug="jokery" /> og <CasinoMention slug="lussurio" /> giver frihed, større bonusser og adgang til internationale jackpot-netværk.
        </p>
      </section>
    </article>

    <Faq items={FAQ_ITEMS.slice(0, 6)} title="Spørgsmål om udenlandske casinoer" />
    <OfferReprise />
    <AuthorBox />
    <RelatedPages currentPath={page.path} />
  </div>
</BaseLayout>

<style>
  .page-layout { padding-bottom: 3rem; }
  .content { margin-top: 2rem; }
</style>
