---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/TrustBar.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import OfferWall from '../components/OfferWall.astro';
import OfferReprise from '../components/OfferReprise.astro';
import Faq from '../components/Faq.astro';
import AuthorBox from '../components/AuthorBox.astro';
import RelatedPages from '../components/RelatedPages.astro';
import CasinoMention from '../components/CasinoMention.astro';
import { CASINOS } from '../config/casinos';
import { CLUSTER_PAGES, FAQ_ITEMS } from '../config/site';
import {
  buildGraph, organizationSchema, websiteSchema, authorSchema,
  webPageSchema, articleSchema, breadcrumbSchema, faqSchema, casinoItemListSchema,
} from '../lib/schema';

const page = CLUSTER_PAGES[2];
const schema = buildGraph([
  organizationSchema(), websiteSchema(), authorSchema(),
  webPageSchema({ path: page.path, title: page.title, description: page.description }),
  articleSchema({ path: page.path, title: page.title, description: page.description, headline: page.h1 }),
  breadcrumbSchema([{ name: 'Forside', path: '/' }, { name: 'Spil uden ROFUS', path: page.path }]),
  casinoItemListSchema(CASINOS, page.path, 'Spil uden ROFUS 2026'),
  faqSchema(FAQ_ITEMS.slice(2, 8)),
]);
---

<BaseLayout title={page.title} description={page.description} path={page.path} keywords={page.keywords} schema={schema}>
  <TrustBar />
  <div class="container page-layout">
    <Breadcrumbs crumbs={[{ name: 'Forside', path: '/' }, { name: 'Spil uden ROFUS', path: page.path }]} />
    <PageHero compact h1={page.h1} intro="Spil slots, live casino og jackpots uden ROFUS-begrænsninger hos internationalt licenserede operatører." />
    <OfferWall title="Casinoer til spil uden ROFUS" subtitle="Tusindvis af spil · Ingen indskudsgrænser · Hurtig start" />

    <article class="prose content reveal">
      <section>
        <h2>Hvad betyder spil uden ROFUS?</h2>
        <p>
          At <strong>spille uden ROFUS</strong> betyder, at du spiller på et internationalt casino, der ikke deler data med det danske ROFUS-register. Du kan oprette konto frit og spille uden de begrænsninger, som dansklicenserede sider pålægger.
        </p>
      </section>

      <section>
        <h2>Populære spiltyper</h2>
        <ul>
          <li><strong>Spilleautomater</strong> — Gates of Olympus, Sweet Bonanza, Starburst og tusindvis flere</li>
          <li><strong>Live casino</strong> — Roulette, blackjack og baccarat med rigtige dealere</li>
          <li><strong>Jackpots</strong> — Progressive præmiepuljer over 35 mio. kr. hos <CasinoMention slug="thorfortune" /></li>
          <li><strong>Bordspil</strong> — Videopoker, craps og casino hold'em</li>
        </ul>
      </section>

      <section>
        <h2>Bedste sider til spil uden ROFUS</h2>
        <p>
          <CasinoMention slug="godz" /> har det største spilkatalog med 6.500+ titler. <CasinoMention slug="winbeatz" /> er bedst på mobil, og <CasinoMention slug="vox" /> giver 600 free spins til nye spillere.
        </p>
      </section>
    </article>

    <Faq items={FAQ_ITEMS.slice(2, 8)} title="Spørgsmål om spil uden ROFUS" />
    <OfferReprise />
    <AuthorBox />
    <RelatedPages currentPath={page.path} />
  </div>
</BaseLayout>

<style>
  .page-layout { padding-bottom: 3rem; }
  .content { margin-top: 2rem; }
</style>
