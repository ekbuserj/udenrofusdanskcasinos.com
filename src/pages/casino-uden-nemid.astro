---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/TrustBar.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import OfferWall from '../components/OfferWall.astro';
import OfferReprise from '../components/OfferReprise.astro';
import Faq from '../components/Faq.astro';
import AuthorBox from '../components/AuthorBox.astro';
import RelatedPages from '../components/RelatedPages.astro';
import CasinoMention from '../components/CasinoMention.astro';
import { CASINOS } from '../config/casinos';
import { CLUSTER_PAGES, FAQ_ITEMS } from '../config/site';
import {
  buildGraph, organizationSchema, websiteSchema, authorSchema,
  webPageSchema, articleSchema, breadcrumbSchema, faqSchema, casinoItemListSchema,
} from '../lib/schema';

const page = CLUSTER_PAGES[4];
const schema = buildGraph([
  organizationSchema(), websiteSchema(), authorSchema(),
  webPageSchema({ path: page.path, title: page.title, description: page.description }),
  articleSchema({ path: page.path, title: page.title, description: page.description, headline: page.h1 }),
  breadcrumbSchema([{ name: 'Forside', path: '/' }, { name: 'Casino uden NemID', path: page.path }]),
  casinoItemListSchema(CASINOS, page.path, 'Casino uden NemID 2026'),
  faqSchema([FAQ_ITEMS[7], ...FAQ_ITEMS.slice(0, 3)]),
]);
---

<BaseLayout title={page.title} description={page.description} path={page.path} keywords={page.keywords} schema={schema}>
  <TrustBar />
  <div class="container page-layout">
    <Breadcrumbs crumbs={[{ name: 'Forside', path: '/' }, { name: 'Casino uden NemID', path: page.path }]} />
    <PageHero compact h1={page.h1} intro="NemID er historie — udenlandske casinoer kræver hverken NemID eller MitID. Se de bedste sider med nem registrering i 2026." />
    <OfferWall title="Casino uden NemID" subtitle="E-mail registrering · Ingen dansk login · Store bonusser" />

    <article class="prose content reveal">
      <section>
        <h2>Fra NemID til MitID — og videre til udenlandske casinoer</h2>
        <p>
          NemID blev erstattet af MitID i 2021–2022. Danske casinoer bruger nu udelukkende MitID. Et <strong>casino uden NemID</strong> — og uden MitID — giver dig en alternativ vej: registrering med e-mail hos internationale operatører.
        </p>
      </section>

      <section>
        <h2>Fordele ved casino uden NemID</h2>
        <ul>
          <li>Hurtig registrering på 1–2 minutter</li>
          <li>Ingen kobling til dansk identitetsinfrastruktur</li>
          <li>Større bonusser end dansklicenserede sider</li>
          <li>Adgang til internationale spil og jackpots</li>
        </ul>
        <p>Prøv <CasinoMention slug="jokery" /> med 300% bonus eller <CasinoMention slug="scored" /> med casino og sportsbook i ét.</p>
      </section>
    </article>

    <Faq items={[FAQ_ITEMS[7], ...FAQ_ITEMS.slice(0, 3)]} title="Spørgsmål om casino uden NemID" />
    <OfferReprise />
    <AuthorBox />
    <RelatedPages currentPath={page.path} />
  </div>
</BaseLayout>

<style>
  .page-layout { padding-bottom: 3rem; }
  .content { margin-top: 2rem; }
</style>
