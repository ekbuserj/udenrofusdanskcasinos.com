---
import { TOP_CASINO } from '../config/casinos';
---

<div class="sticky-cta" id="sticky-cta" hidden>
  <div class="sticky-inner container">
    <div class="sticky-info">
      <span class="sticky-label">Bedste valg</span>
      <strong>{TOP_CASINO.name}</strong>
      <span class="sticky-bonus">{TOP_CASINO.bonus}</span>
    </div>
    <a href={TOP_CASINO.url} target="_blank" rel="sponsored nofollow noopener" class="btn btn-primary sticky-btn">
      Få bonus
    </a>
  </div>
</div>

<script>
  const sticky = document.getElementById('sticky-cta');
  const target = document.getElementById('top-casinoer');
  if (sticky && target) {
    const io = new IntersectionObserver(
      ([entry]) => {
        sticky.hidden = entry.isIntersecting || entry.boundingClientRect.top > 0;
      },
      { threshold: 0, rootMargin: '0px' }
    );
    io.observe(target);
    window.addEventListener('scroll', () => {
      if (window.scrollY < 200) sticky.hidden = true;
    }, { passive: true });
  }
</script>

<style>
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    padding: 0.65rem 0;
    background: rgba(7, 26, 21, 0.96);
    backdrop-filter: blur(12px);
    border-top: 1px solid var(--gold-line);
    box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.35);
    animation: slideUp 0.35s var(--ease-out);
  }

  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  .sticky-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .sticky-info {
    display: flex;
    flex-direction: column;
    color: var(--cream);
    font-size: 0.78rem;
    min-width: 0;
  }
  .sticky-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .sticky-info strong { font-size: 0.92rem; }
  .sticky-bonus { color: rgba(243, 236, 224, 0.65); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .sticky-btn {
    flex-shrink: 0;
    padding: 0.65rem 1.1rem;
    font-size: 0.82rem;
  }

  @media (min-width: 720px) {
    .sticky-cta { display: none; }
  }
</style>
