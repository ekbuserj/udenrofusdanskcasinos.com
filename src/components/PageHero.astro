---
import { SITE } from '../config/site';

interface Props {
  h1: string;
  intro?: string;
  compact?: boolean;
}

const { h1, intro, compact = false } = Astro.props;
---

<div class:list={['hero', { 'hero--compact': compact }]}>
  <div class="hero-accent" aria-hidden="true"></div>
  <p class="label hero-updated">Opdateret {SITE.dateModifiedHuman}</p>
  <h1>{h1}</h1>
  {intro && <p class="hero-intro">{intro}</p>}
</div>

<style>
  .hero {
    position: relative;
    padding: 1.25rem 0 0.75rem;
  }

  .hero--compact {
    padding: 0.65rem 0 0.5rem;
  }

  .hero--compact h1 {
    font-size: clamp(1.25rem, 1rem + 1vw, 1.65rem);
    margin-bottom: 0.35rem;
  }

  .hero--compact .hero-intro {
    font-size: 0.82rem;
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-accent {
    position: absolute;
    top: 0;
    left: -1rem;
    width: 4px;
    height: 2.5rem;
    background: linear-gradient(180deg, var(--danish-red) 0%, var(--gold) 100%);
    border-radius: 2px;
  }

  .hero-updated { margin-bottom: 0.35rem; }

  .hero-intro {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0;
    max-width: 58ch;
  }

  @media (max-width: 719px) {
    .hero:not(.hero--compact) .hero-intro { display: none; }
  }
</style>
