---
import type { Casino } from '../config/casinos';
import PaymentIcon from './PaymentIcon.astro';

interface Props {
  casino: Casino;
  rank: number;
  eager?: boolean;
}

const { casino: c, rank, eager = false } = Astro.props;

const badgeLabel =
  rank === 1
    ? '#1 Valg'
    : c.badge === 'EDITORS_PICK'
      ? 'Redaktørens valg'
      : c.badge === 'TOP_RATED'
        ? 'Topbedømt'
        : null;

const reviews = c.reviewCount.toLocaleString('da-DK');
const shownPayments = c.paymentMethods.slice(0, 5);
const extraPayments = c.paymentMethods.length - shownPayments.length;
---

<article class:list={['offer-card', 'reveal', { 'offer-card--top': rank === 1 }]} id={c.slug}>
  <div class="offer-rank" aria-label={`Placering ${rank}`}>
    <span class="rank-num">{rank}</span>
  </div>

  <div class="offer-main">
    <header class="offer-head">
      <a
        href={c.url}
        target="_blank"
        rel="sponsored nofollow noopener"
        class="logo-link"
        style={`background:${c.logoBg}`}
        aria-label={`Besøg ${c.name}`}
      >
        <img
          src={c.logo}
          alt={`${c.name} logo`}
          width={c.logoWidth}
          height={c.logoHeight}
          loading={eager ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={eager ? 'high' : 'auto'}
        />
      </a>

      <div class="offer-meta">
        <div class="name-row">
          <h3 class="offer-name">{c.name}</h3>
          {badgeLabel && <span class="badge">{badgeLabel}</span>}
        </div>
        <p class="rating" aria-label={`Score ${c.rating} ud af 10`}>
          <span class="stars" aria-hidden="true">★★★★★</span>
          <strong>{c.rating.toFixed(1)}</strong>/10 · {reviews} anmeldelser
        </p>
      </div>
    </header>

    <div class="offer-bonus">
      <span class="label">Velkomstbonus</span>
      <p class="bonus-text">{c.bonus} <span class="bonus-fs">{c.bonusSpins}</span></p>
      <p class="highlight">{c.highlight}</p>
    </div>

    <dl class="specs">
      <div><dt>Min. indskud</dt><dd>{c.minDeposit}</dd></div>
      <div><dt>Udbetaling</dt><dd>{c.payoutTime}</dd></div>
      <div><dt>Licens</dt><dd>{c.license}</dd></div>
    </dl>

    <ul class="pay-icons" aria-label="Betalingsmetoder">
      {shownPayments.map((m) => (
        <li>
          <PaymentIcon method={m} />
        </li>
      ))}
      {extraPayments > 0 && <li class="more">+{extraPayments}</li>}
    </ul>
  </div>

  <div class="offer-cta">
    <a href={c.url} target="_blank" rel="sponsored nofollow noopener" class="btn btn-primary cta-btn">
      Få bonus nu
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <p class="terms">18+ · Regler & vilkår gælder</p>
  </div>
</article>

<style>
  .offer-card {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-areas:
      'rank main'
      'cta cta';
    background:
      linear-gradient(145deg, #faf6ef 0%, #f0e8d8 100%);
    border: 1px solid var(--gold-line);
    border-radius: var(--radius-md);
    box-shadow:
      var(--shadow-sm),
      0 0 0 1px rgba(255, 255, 255, 0.4) inset;
    overflow: hidden;
    scroll-margin-top: calc(var(--header-h) + 1rem);
    transition: box-shadow 0.25s var(--ease-out), transform 0.25s var(--ease-out), border-color 0.25s;
  }

  @media (hover: hover) {
    .offer-card:hover {
      box-shadow: var(--shadow-md), 0 0 24px rgba(201, 168, 76, 0.12);
      transform: translateY(-2px);
      border-color: var(--gold);
    }
  }

  .offer-card--top {
    border-color: rgba(196, 18, 46, 0.45);
    box-shadow: var(--shadow-md), 0 0 0 1px rgba(196, 18, 46, 0.15), 0 0 32px rgba(201, 168, 76, 0.1);
  }

  .offer-rank {
    grid-area: rank;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 1rem 0.65rem 0;
    background: linear-gradient(180deg, var(--felt-mid) 0%, var(--felt) 100%);
    border-right: 1px solid var(--gold-line);
  }

  .rank-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--gold);
    line-height: 1;
  }

  .offer-card--top .rank-num { color: #fff; text-shadow: 0 0 12px rgba(196, 18, 46, 0.6); }

  .offer-main {
    grid-area: main;
    padding: 0.85rem 1rem 1rem;
    min-width: 0;
  }

  .offer-head {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(26, 20, 14, 0.1);
  }

  .logo-link {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.5rem;
    height: 3.2rem;
    border-radius: var(--radius-sm);
    padding: 0.4rem;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.08);
    transition: opacity 0.2s;
  }
  .logo-link:hover { opacity: 0.85; }
  .logo-link img {
    max-width: 100%;
    max-height: 2.4rem;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .offer-meta { min-width: 0; flex: 1; }

  .name-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.2rem;
  }

  .offer-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    margin: 0;
    line-height: 1.2;
    color: var(--ink);
  }

  .badge {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    background: var(--gold-soft);
    color: #7a6218;
    border: 1px solid var(--gold-line);
    border-radius: 999px;
  }

  .rating {
    margin: 0;
    font-size: 0.75rem;
    color: var(--ink-muted);
  }
  .rating strong { color: var(--ink); }
  .stars { color: var(--gold); letter-spacing: -0.05em; margin-right: 0.2rem; }

  .offer-bonus { margin-bottom: 0.75rem; }
  .offer-bonus .label { color: #8a7320; }
  .bonus-text {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1rem + 0.8vw, 1.45rem);
    color: var(--danish-red);
    margin: 0.15rem 0 0.35rem;
    line-height: 1.2;
    max-width: none;
  }
  .bonus-fs { display: block; font-size: 0.72em; color: var(--ink); margin-top: 0.1rem; }
  .highlight { font-size: 0.84rem; color: var(--ink-soft); margin: 0; line-height: 1.5; }

  .specs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    margin: 0 0 0.75rem;
  }
  .specs div { display: flex; flex-direction: column; }
  .specs dt {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .specs dd { margin: 0; font-size: 0.85rem; font-weight: 600; color: var(--ink); }

  .offer-cta {
    grid-area: cta;
    padding: 0.85rem 1rem;
    background: linear-gradient(180deg, #ebe2d2 0%, #e2d7c4 100%);
    border-top: 1px solid rgba(26, 20, 14, 0.1);
  }

  .cta-btn { width: 100%; }
  .terms {
    margin: 0.45rem 0 0;
    font-size: 0.65rem;
    text-align: center;
    color: var(--ink-muted);
  }

  @media (min-width: 720px) {
    .offer-card {
      grid-template-columns: auto 1fr 11.5rem;
      grid-template-areas: 'rank main cta';
    }
    .offer-rank { align-items: center; padding: 0 0.85rem; }
    .rank-num { font-size: 2rem; }
    .offer-cta {
      border-top: 0;
      border-left: 1px solid rgba(26, 20, 14, 0.1);
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: linear-gradient(180deg, #f3ece0 0%, #ebe2d2 100%);
    }
    .logo-link { width: 5.5rem; height: 3.8rem; }
  }
</style>
