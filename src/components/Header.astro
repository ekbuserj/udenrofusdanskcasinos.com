---
import { SITE, CLUSTER_PAGES } from '../config/site';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${SITE.brand} — forsiden`}>
      <span class="brand-mark" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <rect width="28" height="28" rx="7" fill="#0c2e24"/>
          <rect x="1" y="1" width="26" height="26" rx="6" stroke="#c9a84c" stroke-width="1.5" fill="none"/>
          <path d="M14 7v14M7 14h14" stroke="#c4122e" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-name">{SITE.brandShort}</span>
        <span class="brand-sub">Casino Guide</span>
      </span>
    </a>

    <nav class="nav" aria-label="Hovednavigation">
      <ul>
        {CLUSTER_PAGES.map((p) => (
          <li>
            <a href={p.path} class:list={[{ active: currentPath === p.path }]} aria-current={currentPath === p.path ? 'page' : undefined}>
              {p.navLabel}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="#top-casinoer" class="btn btn-primary header-cta">Se bonusser</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-h);
    background: rgba(7, 26, 21, 0.9);
    backdrop-filter: blur(14px) saturate(1.3);
    border-bottom: 1px solid var(--gold-line);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 100%;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--cream);
    flex-shrink: 0;
  }
  .brand:hover { color: var(--gold-bright); }

  .brand-text { display: flex; flex-direction: column; line-height: 1.1; }
  .brand-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.01em;
    color: var(--cream);
  }
  .brand-sub {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .nav { display: none; margin-left: auto; }
  .nav ul {
    display: flex;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav a {
    display: block;
    padding: 0.4rem 0.65rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(243, 236, 224, 0.75);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
  }
  .nav a:hover, .nav a.active {
    color: var(--gold-bright);
    background: rgba(201, 168, 76, 0.12);
  }

  .header-cta {
    margin-left: auto;
    padding: 0.5rem 0.9rem;
    font-size: 0.78rem;
  }

  @media (min-width: 900px) {
    .nav { display: block; }
    .header-cta { margin-left: 0.75rem; }
  }

  @media (max-width: 899px) {
    .brand-sub { display: none; }
    .brand-name { font-size: 0.95rem; }
  }
</style>
