---
import { TOTAL_REVIEWS, AVG_RATING } from '../config/casinos';
import { SITE as SITE_CONFIG } from '../config/site';
---

<div class="trust-bar">
  <div class="container trust-inner">
    <div class="trust-item">
      <span class="trust-icon" aria-hidden="true">✓</span>
      <span><strong>Uafhængigt testet</strong> · {SITE_CONFIG.dateModifiedHuman}</span>
    </div>
    <div class="trust-item">
      <span class="trust-icon" aria-hidden="true">★</span>
      <span><strong>{AVG_RATING}/10</strong> gns. score</span>
    </div>
    <div class="trust-item">
      <span class="trust-icon" aria-hidden="true">⚡</span>
      <span><strong>Hurtig udbetaling</strong> · 0–24 t</span>
    </div>
    <div class="trust-item trust-hide-mobile">
      <span class="trust-icon" aria-hidden="true">◆</span>
      <span><strong>{TOTAL_REVIEWS.toLocaleString('da-DK')}+</strong> anmeldelser</span>
    </div>
  </div>
</div>

<style>
  .trust-bar {
    background: rgba(0, 0, 0, 0.22);
    border-bottom: 1px solid var(--gold-line);
    padding: 0.45rem 0;
  }

  .trust-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    align-items: center;
    font-size: 0.72rem;
    color: rgba(243, 236, 224, 0.75);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    white-space: nowrap;
  }
  .trust-item strong { color: var(--cream); }

  .trust-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    background: var(--gold-soft);
    border: 1px solid var(--gold-line);
    border-radius: 50%;
    font-size: 0.6rem;
    color: var(--gold);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .trust-hide-mobile { display: none; }
    .trust-inner { gap: 0.35rem 0.85rem; font-size: 0.68rem; }
  }
</style>
