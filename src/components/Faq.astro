---
import type { FaqItem } from '../lib/schema';

interface Props {
  items: FaqItem[];
  title?: string;
}

const { items, title = 'Ofte stillede spørgsmål' } = Astro.props;
---

<section class="faq reveal" aria-labelledby="faq-heading">
  <h2 id="faq-heading">{title}</h2>
  <div class="faq-list">
    {items.map((item, i) => (
      <details class="faq-item" open={i === 0}>
        <summary>{item.q}</summary>
        <p>{item.a}</p>
      </details>
    ))}
  </div>
</section>

<style>
  .faq { margin: 2.5rem 0; }
  .faq-list { display: flex; flex-direction: column; gap: 0.5rem; }

  .faq-item {
    background: rgba(8, 28, 22, 0.72);
    border: 1px solid rgba(201, 168, 76, 0.2);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .faq-item[open] { border-color: rgba(201, 168, 76, 0.4); }

  summary {
    padding: 1rem 1.15rem;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--cream);
  }
  summary::-webkit-details-marker { display: none; }
  summary::after {
    content: '+';
    font-size: 1.2rem;
    color: var(--gold);
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .faq-item[open] summary::after { transform: rotate(45deg); }

  .faq-item p {
    padding: 0 1.15rem 1rem;
    margin: 0;
    color: rgba(243, 236, 224, 0.75);
    font-size: 0.92rem;
    border-top: 1px solid rgba(243, 236, 224, 0.1);
    padding-top: 0.85rem;
  }
</style>
