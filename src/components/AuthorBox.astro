---
import { SITE } from '../config/site';
---

<aside class="author reveal" aria-labelledby="author-heading">
  <div class="author-avatar" aria-hidden="true">{SITE.author.initials}</div>
  <div>
    <p class="label" id="author-heading">Skrevet af</p>
    <p class="author-name">{SITE.author.name}</p>
    <p class="author-role">{SITE.author.role}</p>
    <p class="author-bio">{SITE.author.bio}</p>
  </div>
</aside>

<style>
  .author {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    margin: 2rem 0;
  }

  .author-avatar {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--navy);
    color: var(--white);
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 50%;
  }

  .author-name { font-family: var(--font-display); font-size: 1.1rem; margin: 0.15rem 0 0; }
  .author-role { font-size: 0.82rem; color: var(--danish-red); font-weight: 600; margin: 0 0 0.5rem; }
  .author-bio { font-size: 0.85rem; color: var(--ink-soft); margin: 0; line-height: 1.55; max-width: none; }
</style>
